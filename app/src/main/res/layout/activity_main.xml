<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundMain">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- TÍTULO -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Estadística"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- INPUT -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cvInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/cardBackground"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <EditText
                    android:id="@+id/etNumbersInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ej: 1 2 3 4 5"
                    android:inputType="numberDecimal"
                    android:digits="0123456789. "
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/textSecondary"
                    android:background="@android:color/transparent"
                    android:padding="10dp"/>

                <Button
                    android:id="@+id/btnCalculate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Calcular"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- DATOS ORDENADOS -->
        <TextView
            android:id="@+id/tvLabelSorted"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Datos Ordenados"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/cvInput"
            app:layout_constraintStart_toStartOf="parent"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/cvSortedContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            app:cardCornerRadius="10dp"
            app:cardBackgroundColor="@color/cardBackground"
            app:layout_constraintTop_toBottomOf="@id/tvLabelSorted"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvSortedNumbers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="Esperando datos..."
                android:textColor="@color/textSecondary"/>
        </androidx.cardview.widget.CardView>

        <!-- CARD RESUMEN + 3M -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cvSummary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/cardBackground"
            app:layout_constraintTop_toBottomOf="@id/cvSortedContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp">

                <!-- IZQUIERDA -->
                <LinearLayout
                    android:id="@+id/leftStats"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/rightStats"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView android:id="@+id/tvN" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="n: 0" android:textColor="@color/textSecondary"/>
                    <TextView android:id="@+id/tvMin" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Min: 0" android:textColor="@color/textSecondary"/>
                    <TextView android:id="@+id/tvMax" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Max: 0" android:textColor="@color/textSecondary"/>
                    <TextView android:id="@+id/tvRange" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rango: 0" android:textColor="@color/textSecondary"/>
                    <TextView android:id="@+id/tvClasses" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Clases: 0" android:textColor="@color/textSecondary"/>
                    <TextView android:id="@+id/tvWidth" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Amplitud: 0" android:textColor="@color/textSecondary"/>
                </LinearLayout>

                <!-- DERECHA -->
                <LinearLayout
                    android:id="@+id/rightStats"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="12dp"
                    app:layout_constraintStart_toEndOf="@id/leftStats"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView android:id="@+id/tvMedia" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Media: -" android:textStyle="bold" android:textColor="@color/textPrimary"/>
                    <TextView android:id="@+id/tvMediana" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mediana: -" android:textStyle="bold" android:textColor="@color/textPrimary"/>
                    <TextView android:id="@+id/tvModa" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Moda: -" android:textStyle="bold" android:textColor="@color/textPrimary"/>
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- HEADER TABLA -->
        <LinearLayout
            android:id="@+id/llHeaders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="6"
            android:background="@color/headerBackground"
            android:padding="8dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/cvSummary">

            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="Int." android:gravity="center"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8" android:text="FA" android:gravity="center"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="FAc" android:gravity="center"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:text="FR" android:gravity="center"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="FRAc" android:gravity="center"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvFrequencyTable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/llHeaders"/>

        <!-- FRECUENCIA SIMPLE -->
        <TextView
            android:id="@+id/tvLabelSimple"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Frecuencia por dato"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/rvFrequencyTable"
            app:layout_constraintStart_toStartOf="parent"/>

        <LinearLayout
            android:id="@+id/llHeaderSimple"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:background="@color/headerBackground"
            android:padding="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvLabelSimple">

            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Dato" android:gravity="center"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Rep." android:gravity="center"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvFrecuenciaSimple"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/llHeaderSimple"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>